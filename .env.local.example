# Database (Docker default on port 5433 - change if using external database)
DATABASE_URL="postgresql://izstudio:izstudio123@localhost:5433/izstudio?schema=public"

# Site URL (paylaşım linkleri, Open Graph – canlıda aynı kalabilir)
NEXT_PUBLIC_SITE_URL="https://feelcreativestudio.com"

# NextAuth – Çıkış sonrası yönlendirme için canlıda mutlaka gerçek domain yazın
# Yerel: http://localhost:3000 | Canlı: https://feelcreativestudio.com
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Email (SMTP) – Turkticaret: smtp.turkticaret.net | no-reply@feelcreativestudio.com
# Dolu olursa: hoş geldin, şifre sıfırlama ve sipariş durumu e-postaları gider
SMTP_HOST="smtp.turkticaret.net"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="no-reply@feelcreativestudio.com"
SMTP_PASS="BURAYA_MAIL_ŞİFRESİNİ_YAZ"
EMAIL_FROM="Feel Studio <no-reply@feelcreativestudio.com>"

# Payment (iyzipay-node: https://github.com/iyzico/iyzipay-node)
PAYMENT_PROVIDER="iyzico"
# IYZICO_* veya resmi IYZIPAY_API_KEY / IYZIPAY_SECRET_KEY / IYZIPAY_URI kullanılabilir
IYZICO_SANDBOX="false"
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
# Opsiyonel: IYZIPAY_URI tanımlarsan sandbox/canlı buradan (örn. https://api.iyzipay.com)

# Storage (Optional)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# AWS_BUCKET_NAME=""

# Or Supabase Storage
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# SUPABASE_STORAGE_BUCKET=""
