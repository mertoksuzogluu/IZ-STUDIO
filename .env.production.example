# Canlı sunucu (feelcreativestudio.com) — .env olarak kopyala, şifreleri değiştir

DATABASE_URL="postgresql://izstudio:GÜÇLÜ_ŞİFRE@localhost:5432/izstudio?schema=public"
NEXTAUTH_URL="https://feelcreativestudio.com"
NEXT_PUBLIC_SITE_URL="https://feelcreativestudio.com"
NEXTAUTH_SECRET="openssl-rand-base64-32-ile-üret"

# E-posta (kayıt hoş geldin, sipariş durumu) — no-reply@feelcreativestudio.com
EMAIL_FROM="Feel Studio <no-reply@feelcreativestudio.com>"
# SMTP (yoksa e-postalar sadece loglanır; gönderilmez)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="no-reply@feelcreativestudio.com"
# SMTP_PASS="şifre"

# Opsiyonel: ödeme, storage
# PAYMENT_PROVIDER="mock"
